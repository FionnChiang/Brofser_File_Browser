<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- ── 文件类型 ──────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="文件类型"
            android:textSize="12sp"
            android:textColor="#757575"
            android:textAllCaps="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <RadioGroup
            android:id="@+id/rgFileType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <RadioButton android:id="@+id/rb_type_all"    android:layout_width="match_parent" android:layout_height="36dp" android:text="全部"   android:textSize="14sp" android:checked="true" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_type_folder" android:layout_width="match_parent" android:layout_height="36dp" android:text="文件夹" android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_type_image"  android:layout_width="match_parent" android:layout_height="36dp" android:text="图片"   android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_type_video"  android:layout_width="match_parent" android:layout_height="36dp" android:text="视频"   android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_type_audio"  android:layout_width="match_parent" android:layout_height="36dp" android:text="音频"   android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_type_text"   android:layout_width="match_parent" android:layout_height="36dp" android:text="文本"   android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_type_other"  android:layout_width="match_parent" android:layout_height="36dp" android:text="其他"   android:textSize="14sp" android:paddingStart="8dp" />

        </RadioGroup>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="4dp" android:layout_marginBottom="4dp" />

        <!-- ── 文件大小 ──────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="文件大小"
            android:textSize="12sp"
            android:textColor="#757575"
            android:textAllCaps="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <RadioGroup
            android:id="@+id/rgFileSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <RadioButton android:id="@+id/rb_size_all"    android:layout_width="match_parent" android:layout_height="36dp" android:text="全部"            android:textSize="14sp" android:checked="true" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_size_small"  android:layout_width="match_parent" android:layout_height="36dp" android:text="小（&lt;1 MB）"  android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_size_medium" android:layout_width="match_parent" android:layout_height="36dp" android:text="中（1–100 MB）"  android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_size_large"  android:layout_width="match_parent" android:layout_height="36dp" android:text="大（&gt;100 MB）" android:textSize="14sp" android:paddingStart="8dp" />

        </RadioGroup>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="4dp" android:layout_marginBottom="4dp" />

        <!-- ── 修改日期 ──────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="修改日期"
            android:textSize="12sp"
            android:textColor="#757575"
            android:textAllCaps="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <RadioGroup
            android:id="@+id/rgDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <RadioButton android:id="@+id/rb_date_all"   android:layout_width="match_parent" android:layout_height="36dp" android:text="全部" android:textSize="14sp" android:checked="true" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_date_today" android:layout_width="match_parent" android:layout_height="36dp" android:text="今天" android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_date_week"  android:layout_width="match_parent" android:layout_height="36dp" android:text="本周" android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_date_month" android:layout_width="match_parent" android:layout_height="36dp" android:text="本月" android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_date_year"  android:layout_width="match_parent" android:layout_height="36dp" android:text="今年" android:textSize="14sp" android:paddingStart="8dp" />

        </RadioGroup>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="4dp" android:layout_marginBottom="4dp" />

        <!-- ── 排序方式 ──────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="排序方式"
            android:textSize="12sp"
            android:textColor="#757575"
            android:textAllCaps="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <RadioGroup
            android:id="@+id/rgSortField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <RadioButton android:id="@+id/rb_sort_name" android:layout_width="match_parent" android:layout_height="36dp" android:text="名称"     android:textSize="14sp" android:checked="true" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_sort_date" android:layout_width="match_parent" android:layout_height="36dp" android:text="修改日期" android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_sort_size" android:layout_width="match_parent" android:layout_height="36dp" android:text="文件大小" android:textSize="14sp" android:paddingStart="8dp" />
            <RadioButton android:id="@+id/rb_sort_type" android:layout_width="match_parent" android:layout_height="36dp" android:text="文件类型" android:textSize="14sp" android:paddingStart="8dp" />

        </RadioGroup>

        <RadioGroup
            android:id="@+id/rgSortDir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <RadioButton android:id="@+id/rb_sort_asc"  android:layout_width="wrap_content" android:layout_height="36dp" android:text="升序 ↑" android:textSize="14sp" android:checked="true" android:layout_marginEnd="24dp" />
            <RadioButton android:id="@+id/rb_sort_desc" android:layout_width="wrap_content" android:layout_height="36dp" android:text="降序 ↓" android:textSize="14sp" />

        </RadioGroup>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="4dp" android:layout_marginBottom="4dp" />

        <!-- ── 搜索范围 ──────────────────────────── -->
        <CheckBox
            android:id="@+id/cbSearchGlobal"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="搜索全局文件"
            android:textSize="14sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginTop="4dp" android:layout_marginBottom="4dp" />

        <!-- ── 选择全部结果 ──────────────────────── -->
        <TextView
            android:id="@+id/tvSelectAllResults"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="选择全部搜索结果"
            android:textSize="14sp"
            android:textColor="@color/colorPrimary"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>
</ScrollView>
